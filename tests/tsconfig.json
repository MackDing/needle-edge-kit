{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["**/*.ts", "../mobile/src/**/*.ts", "../mobile/src/**/*.tsx"]
}
